# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit your real keys.
#
# In Supabase Dashboard → Project Settings → API → "Project API keys"
# Use the PUBLISHABLE key (sb_publishable_...). NEVER the Secret key.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE
